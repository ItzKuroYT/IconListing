{
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/data/(.*)",
      "dest": "/api/index.js?action=blockedData"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/api/index.js?action=sitemap"
    },
    {
      "src": "/server/([^/]+)/?",
      "dest": "/api/index.js?action=serverPage&slug=$1"
    },
    {
      "src": "/api",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
